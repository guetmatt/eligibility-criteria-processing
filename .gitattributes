# 1. Handle line endings for all text files
* text=auto eol=lf

# 2. Ensure Python files are always treated as text
*.py text

# 3. Explicitly handle Large Files (LFS) and treat as binary (-text)
*.safetensors filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text